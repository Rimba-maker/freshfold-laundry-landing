---
const footerLinks = {
  Layanan: ['Cuci Kiloan', 'Cuci Setrika', 'Express', 'Dry Cleaning', 'Specialty'],
  Perusahaan: ['Tentang Kami', 'Coverage Area', 'Karir', 'Blog', 'Press'],
  Bantuan: ['FAQ', 'Cara Kerja', 'Garansi & Kebijakan', 'Hubungi Kami', 'B2B / Korporat'],
};
---

<footer style="background-color: var(--color-ink); color: rgba(255,255,255,0.7); padding: 72px 0 0;">
  <div class="container-fresh">
    <!-- Top row -->
    <div class="footer-grid">
      <!-- Brand -->
      <div>
        <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none; margin-bottom: 16px;">
          <div style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--color-primary); display: flex; align-items: center; justify-content: center;">
            <svg width="18" height="18" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="14" cy="14" r="14" fill="#ff385c"/>
              <circle cx="14" cy="14" r="5" fill="white"/>
            </svg>
          </div>
          <span style="font-family: var(--font-display); font-size: 20px; font-weight: 800; color: #fff; letter-spacing: -0.03em;">FreshFold</span>
        </a>
        <p style="font-size: 14px; line-height: 1.7; color: rgba(255,255,255,0.55); margin-bottom: 20px; max-width: 240px;">
          More time for what matters.<br/>We'll handle the laundry.
        </p>
        <!-- Sosmed -->
        <div style="display: flex; gap: 10px;">
          {['📷', '🎵', '▶️'].map((icon) => (
            <a
              href="#"
              style="width: 36px; height: 36px; border-radius: 50%; background-color: rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; font-size: 16px; text-decoration: none; transition: background-color 0.2s ease;"
              onmouseover="this.style.backgroundColor='rgba(255,255,255,0.16)'"
              onmouseout="this.style.backgroundColor='rgba(255,255,255,0.08)'"
            >
              {icon}
            </a>
          ))}
        </div>
      </div>

      <!-- Link columns -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h4 style="font-family: var(--font-display); font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 16px; letter-spacing: 0;">{category}</h4>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
            {links.map(link => (
              <li>
                <a
                  href="#"
                  style="font-size: 14px; color: rgba(255,255,255,0.55); text-decoration: none; transition: color 0.15s ease;"
                  onmouseover="this.style.color='rgba(255,255,255,0.9)'"
                  onmouseout="this.style.color='rgba(255,255,255,0.55)'"
                >
                  {link}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom row -->
    <div class="footer-bottom">
      <div style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
        <p style="font-size: 13px; color: rgba(255,255,255,0.4); margin: 0;">
          © 2025 FreshFold Laundry. All rights reserved.
        </p>
        <div style="display: flex; gap: 16px;">
          {['Privacy Policy', 'Terms of Service'].map(link => (
            <a
              href="#"
              style="font-size: 13px; color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.15s ease;"
              onmouseover="this.style.color='rgba(255,255,255,0.7)'"
              onmouseout="this.style.color='rgba(255,255,255,0.4)'"
            >
              {link}
            </a>
          ))}
        </div>
      </div>

      <div style="display: flex; align-items: center; gap: 16px;">
        <div style="display: flex; align-items: center; gap: 6px; font-size: 13px; color: rgba(255,255,255,0.4);">
          <span style="width: 8px; height: 8px; border-radius: 50%; background-color: #10b981; display: inline-block; animation: pulse 2s infinite;"></span>
          Layanan aktif 06:00 - 22:00
        </div>
        <div style="font-size: 13px; color: rgba(255,255,255,0.4);">
          📍 Jl. Tendean, Jakarta Selatan
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Footer mobile khusus untuk elemen footer-bottom child */
  @media (max-width: 768px) {
    footer {
      padding: 48px 0 0 !important;
    }
    .footer-bottom > div:last-child {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
